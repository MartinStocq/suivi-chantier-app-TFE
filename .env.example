# --- CONFIGURATION SYSTÈME ---
NODE_ENV=development

# --- BASE DE DONNÉES (Prisma) ---
# Si vous utilisez Docker avec Supabase en local, le port est généralement 54322.
# Pour une installation PostgreSQL classique, utilisez le port 5432.
DATABASE_URL="postgresql://postgres:postgres@localhost:54322/suivi_chantier"

# --- SUPABASE (Authentification & Stockage) ---
# Ces valeurs sont nécessaires pour l'authentification et le stockage des photos.
# En local avec le CLI Supabase, l'URL est http://localhost:54321
NEXT_PUBLIC_SUPABASE_URL="http://localhost:54321"
NEXT_PUBLIC_SUPABASE_ANON_KEY="votre_cle_anon_supabase"

# --- CONFIGURATION EMAIL (Facultatif en local) ---
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=465
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_SECURE=true

# --- SÉCURITÉ & AUTOMATISATION ---
# Utilisé pour sécuriser les routes de synchronisation (API Meteo)
CRON_SECRET="choisissez_un_secret_aleatoire_long"
