generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Utilisateur {
  id              String                @id @default(uuid())
  nom             String
  email           String                @unique
  role            Role                  @default(OUVRIER)
  createdAt       DateTime              @default(now()) @map("created_at")
  approuve        Boolean               @default(false)
  avatarPath      String?               @map("avatar_path")
  telephone       String?
  actionsJournal  ActionJournal[]
  affectations    AffectationChantier[]
  chantiersCreés Chantier[]            @relation("ChantierCreePar")
  notifications   Notification[]
  photosPrises    Photo[]               @relation("PhotoPrise")
  pointages       Pointage[]
  exports         RapportExport[]

  @@map("utilisateurs")
}

model Adresse {
  id         String     @id @default(uuid())
  rue        String
  numero     String
  codePostal String     @map("code_postal")
  ville      String
  pays       String
  latitude   Float?
  longitude  Float?
  chantiers  Chantier[]

  @@map("adresses")
}

model Client {
  id        String     @id @default(uuid())
  nom       String
  telephone String?
  email     String?
  chantiers Chantier[]

  @@map("clients")
}

model Chantier {
  id              String                @id @default(uuid())
  titre           String
  description     String?
  statut          StatutChantier        @default(EN_ATTENTE)
  dateDebutPrevue DateTime              @map("date_debut_prevue") @db.Date
  dateFinPrevue   DateTime?             @map("date_fin_prevue") @db.Date
  createdAt       DateTime              @default(now()) @map("created_at")
  clientId        String                @map("id_client")
  adresseId       String                @map("id_adresse")
  createdById     String                @map("created_by")
  actionsJournal  ActionJournal[]
  affectations    AffectationChantier[]
  createdBy       Utilisateur           @relation("ChantierCreePar", fields: [createdById], references: [id])
  adresse         Adresse               @relation(fields: [adresseId], references: [id])
  client          Client                @relation(fields: [clientId], references: [id])
  meteoSnapshots  MeteoSnapshot[]
  photos          Photo[]
  pointages       Pointage[]
  rapports        RapportExport[]

  @@map("chantiers")
}

model AffectationChantier {
  id              String      @id @default(uuid())
  roleSurChantier Role        @map("role_sur_chantier")
  dateDebut       DateTime    @map("date_debut") @db.Date
  dateFin         DateTime?   @map("date_fin") @db.Date
  chantierId      String      @map("id_chantier")
  userId          String      @map("id_user")
  chantier        Chantier    @relation(fields: [chantierId], references: [id])
  user            Utilisateur @relation(fields: [userId], references: [id])

  @@map("affectations_chantier")
}

model Photo {
  id          String      @id @default(uuid())
  takenAt     DateTime    @default(now()) @map("taken_at")
  type        TypePhoto
  storagePath String      @map("storage_path")
  commentaire String?
  chantierId  String      @map("id_chantier")
  takenById   String      @map("taken_by")
  chantier    Chantier    @relation(fields: [chantierId], references: [id])
  takenBy     Utilisateur @relation("PhotoPrise", fields: [takenById], references: [id])

  @@map("photos")
}

model RapportExport {
  id           String       @id @default(uuid())
  exportedAt   DateTime     @default(now()) @map("exported_at")
  format       FormatExport
  type         String
  chantierId   String       @map("id_chantier")
  exportedById String       @map("exported_by")
  exportedBy   Utilisateur  @relation(fields: [exportedById], references: [id])
  chantier     Chantier     @relation(fields: [chantierId], references: [id])

  @@map("rapports_export")
}

model MeteoSnapshot {
  id           String   @id @default(uuid())
  dateSnapshot DateTime @default(now()) @map("date_snapshot")
  source       String
  payload      String
  chantierId   String   @map("id_chantier")
  chantier     Chantier @relation(fields: [chantierId], references: [id])

  @@map("meteo_snapshots")
}

model Pointage {
  id            String      @id @default(uuid())
  date          DateTime    @db.Date
  debut         DateTime
  fin           DateTime
  duree         Float
  commentaire   String?
  createdAt     DateTime    @default(now()) @map("created_at")
  chantierId    String      @map("id_chantier")
  utilisateurId String      @map("id_utilisateur")
  chantier      Chantier    @relation(fields: [chantierId], references: [id])
  utilisateur   Utilisateur @relation(fields: [utilisateurId], references: [id])

  @@map("pointages")
}

model ActionJournal {
  id         String            @id @default(uuid())
  action     TypeActionJournal
  details    String?
  createdAt  DateTime          @default(now()) @map("created_at")
  chantierId String            @map("id_chantier")
  auteurId   String            @map("id_auteur")
  auteur     Utilisateur       @relation(fields: [auteurId], references: [id], onDelete: Cascade)
  chantier   Chantier          @relation(fields: [chantierId], references: [id], onDelete: Cascade)

  @@map("action_journal")
}

model Notification {
  id        String      @id @default(uuid())
  titre     String
  message   String
  lu        Boolean     @default(false)
  createdAt DateTime    @default(now()) @map("created_at")
  userId    String      @map("id_utilisateur")
  lien      String?
  user      Utilisateur @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

enum Role {
  OUVRIER
  CHEF_CHANTIER
}

enum StatutChantier {
  EN_ATTENTE
  EN_COURS
  TERMINE
  SUSPENDU
}

enum TypePhoto {
  AVANT
  APRES
}

enum TypeActionJournal {
  CREATION_CHANTIER
  CHANGEMENT_STATUT
  AJOUT_PHOTO
  AFFECTATION_OUVRIER
  RETRAIT_OUVRIER
  POINTAGE
}

enum FormatExport {
  CSV
  PDF
}
